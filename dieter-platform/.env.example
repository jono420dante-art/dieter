# Environment Configuration for DIETER

# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL=postgresql://dieter:dieter@postgres:5432/dieter
DATABASE_ECHO=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ============================================================================
# REDIS
# ============================================================================
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=3600

# ============================================================================
# JWT & AUTH
# ============================================================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=24
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# ============================================================================
# API & URLS
# ============================================================================
API_TITLE=DIETER
API_VERSION=0.1.0
API_DESCRIPTION=Self-hosted autonomous AI orchestration platform
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_BASE_URL=http://localhost:8000
PUBLIC_WEB_URL=http://localhost:3000
OPERATOR_WEB_URL=http://localhost:3001
ENVIRONMENT=development

# ============================================================================
# CORS
# ============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOW_HEADERS=*

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
PUBLIC_RATE_LIMIT_REQUESTS_PER_MINUTE=10

# ============================================================================
# EMAIL SERVICE CONFIGURATION
# ============================================================================
# OWNER MUST CHOOSE ONE: resend, postmark, sendgrid, ses, or smtp
EMAIL_PROVIDER=resend

# Admin & From Addresses
EMAIL_FROM_ADDRESS=noreply@dieter.local
EMAIL_FROM_NAME=DIETER
ADMIN_EMAIL=pielanie420@gmail.com
ADMIN_NOTIFICATION_EMAIL=ops@dieter.local

# Resend (if using Resend)
# OWNER MUST PROVIDE: https://resend.com/api-keys
RESEND_API_KEY=

# Postmark (if using Postmark)
# OWNER MUST PROVIDE: https://account.postmarkapp.com/
POSTMARK_API_KEY=

# SendGrid (if using SendGrid)
# OWNER MUST PROVIDE: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=

# AWS SES (if using SES)
# OWNER MUST PROVIDE AWS credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
SES_SENDER_EMAIL=

# SMTP (if using SMTP, e.g., Gmail App Password)
# Note: pielanie420@gmail.com can be used for development only via App Password
# OWNER MUST PROVIDE Gmail App Password or other SMTP credentials
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TLS=true

# Email Features
EMAIL_VERIFY_SSL=true
EMAIL_TIMEOUT_SECONDS=30
EMAIL_RETRY_ATTEMPTS=3

# ============================================================================
# MODEL PROVIDER CONFIGURATION
# ============================================================================
# OWNER MUST CHOOSE ONE: ollama, openai, anthropic
# Ollama is free and runs locally; others require API keys
LLM_PROVIDER=ollama

# OpenAI (if using OpenAI)
# OWNER MUST PROVIDE: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# Anthropic (if using Anthropic)
# OWNER MUST PROVIDE: https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-sonnet-20240229
ANTHROPIC_TEMPERATURE=0.7
ANTHROPIC_MAX_TOKENS=2000

# Ollama (local, free)
# OWNER MUST: docker pull ollama/ollama && docker run -d ollama/ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=mistral
OLLAMA_TEMPERATURE=0.7
OLLAMA_TIMEOUT_SECONDS=60

# Model Features
MODEL_REQUEST_TIMEOUT_SECONDS=30
MODEL_RETRY_ATTEMPTS=2
MODEL_LOG_REQUESTS=true

# ============================================================================
# WORKER & BACKGROUND JOBS
# ============================================================================
WORKER_ENABLED=true
WORKER_CONCURRENCY=4
WORKER_LOG_LEVEL=info
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ============================================================================
# EMAIL WORKFLOW
# ============================================================================
# Nurture sequence timing
NURTURE_WELCOME_DELAY_SECONDS=300
NURTURE_SEQUENCE_1_DELAY_HOURS=24
NURTURE_SEQUENCE_2_DELAY_HOURS=72
NURTURE_SEQUENCE_3_DELAY_HOURS=168
NURTURE_FOLLOWUP_DELAY_DAYS=14

# ============================================================================
# FINANCE RAIL
# ============================================================================
FINANCE_MIN_LEAD_SCORE=0.5
FINANCE_REVENUE_THRESHOLD=10000
FINANCE_CHURN_ALERT_THRESHOLD=0.3

# ============================================================================
# QUANT SCORING
# ============================================================================
QUANT_ENGAGEMENT_WEIGHT=0.4
QUANT_CONVERSION_WEIGHT=0.35
QUANT_RETENTION_WEIGHT=0.25

# ============================================================================
# TREND ENGINE
# ============================================================================
TREND_LOOKBACK_DAYS=30
TREND_ACCELERATION_THRESHOLD=1.5
TREND_SIGNIFICANCE_LEVEL=0.05

# ============================================================================
# FEEDBACK SYSTEM
# ============================================================================
FEEDBACK_RETENTION_DAYS=365
FEEDBACK_EXPORT_ENABLED=true

# ============================================================================
# SECURITY & MONITORING
# ============================================================================
LOG_LEVEL=info
SENTRY_DSN=
DATADOG_API_KEY=
DATADOG_ENABLED=false

# Health check
HEALTH_CHECK_ENABLED=true

# ============================================================================
# PRODUCTION SETTINGS (set to 'production' to enable stricter checks)
# ============================================================================
DEBUG=true
ALLOW_ORIGINS_ANY=true
